@inherits LayoutComponentBase
@using Microsoft.JSInterop
@inject IJSRuntime JS

<div class="page">
    <main class="main-shell">
        <header class="brand-header px-4">
            <a href="/">
                <h1 class="title">Daphine.io</h1>
            </a>

            <button class="sound-toggle" @onclick="ToggleBackgroundSound">
                @(isMuted ? "Ativar som" : "Silenciar som")
            </button>
        </header>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool isMuted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        isMuted = await JS.InvokeAsync<bool>("getBackgroundAudioMuted");
        StateHasChanged();
    }

    private async Task ToggleBackgroundSound()
    {
        isMuted = await JS.InvokeAsync<bool>("toggleBackgroundAudioMuted");
    }
}