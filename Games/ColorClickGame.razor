@page "/games/color-click"
@using Daphine.Models
@using Microsoft.JSInterop
@inject Daphine.Services.Games.ColorClickGameService GameService
@inject Daphine.Services.Characters.DaphineCharacterService DaphineCharacter
@inject IJSRuntime JS

<div class="game-container">
    <div class="daphine">
        <img src="@DaphineCharacter.GetImagePath()" alt="Personagem Daphine" />
    </div>

    <div class="play-area">
        <div class="instruction">
            <h2>@instructionText</h2>
        </div>

        <div class="cards">
            @foreach (var option in options)
            {
                <button class="card @(option.IsShaking ? "shake" : "")"
                        @onclick="() => SelectOption(option)">
                    <img src="@option.Image" alt="Cor @option.Label" />
                    <span class="color-label">@option.Label</span>
                </button>
            }
        </div>
    </div>

    <audio @ref="audioRef"></audio>
</div>

@code {
    private List<ColorOption> options = new();
    private string targetColorName = string.Empty;
    private string targetColorLabel = string.Empty;
    private string instructionText = string.Empty;

    private ElementReference audioRef;
    private bool hasPlayedWelcome = false;

    protected override async Task OnInitializedAsync()
    {
        if (!hasPlayedWelcome)
        {
            hasPlayedWelcome = true;
            DaphineCharacter.SetSpeaking();
            await PlayAudioAndWait("audio/welcome.mp3");
            await StartRound();
        }
    }

    private async Task StartRound()
    {
        var round = GameService.GenerateRound();

        targetColorName = round.TargetColorName;
        targetColorLabel = round.TargetColorLabel;
        options = round.Options;

        instructionText = $"Aperte a cor {targetColorLabel}";
        DaphineCharacter.SetSpeaking();

        await PlayAudio($"audio/colors/{targetColorName}.mp3");
    }

    private async Task SelectOption(ColorOption option)
    {
        if (option.IsCorrect)
        {
            DaphineCharacter.SetHappy();

            await PlayAudio(GameService.GetRandomSuccessAudio());

            await Task.Delay(1500);

            await StartRound();
            StateHasChanged();
        }
        else
        {
            option.IsShaking = true;
            DaphineCharacter.SetSad();

            await PlayAudio(GameService.GetRandomErrorAudio());

            await Task.Delay(500);

            option.IsShaking = false;
            DaphineCharacter.SetSpeaking();
        }
    }

    private async Task PlayAudio(string src)
    {
        await JS.InvokeVoidAsync("playAudio", src);
    }

    private async Task PlayAudioAndWait(string src)
    {
        await JS.InvokeAsync<object>("playAudioAndWait", src);
    }
}
